    },
    "SanctionRegime": {
      "@id": "ammitto:SanctionRegime"
    },
    "SanctionEffect": {
      "@id": "ammitto:SanctionEffect"
    },
    "TemporalPeriod": {
      "@id": "ammitto:TemporalPeriod"
