    "LegalInstrument": {
      "@id": "ammitto:LegalInstrument"
    },
    "Index": {
      "@id": "ammitto:Index"
    },

    "id": "@id",
    "type": "@type",

    "entityType": {
      "@id": "ammitto:entityType",
